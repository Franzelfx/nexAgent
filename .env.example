# ══════════════════════════════════════════════════════════════════
#  NexAgent Environment Variables
# ══════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values.
#
#  Dokploy: Set these in the Dokploy UI under Environment Variables.

# ── LLM Provider (choose one or use LiteLLM proxy) ────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── LiteLLM Proxy (optional — unifies access to multiple models)
# If set, the agent uses this proxy instead of direct API calls.
LITELLM_BASE_URL=
LITELLM_API_KEY=

# ── Default Model ─────────────────────────────────────────────
# OpenAI-compatible model name (e.g. gpt-4o, claude-3-opus, etc.)
DEFAULT_MODEL=gpt-4o

# ── LangSmith Observability (optional) ────────────────────────
# Enable tracing to see agent execution graphs in LangSmith UI.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexagent
LANGCHAIN_TRACING_V2=false
